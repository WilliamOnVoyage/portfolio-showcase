      "React",
      "Vite",
      "React Flow",
      "Tailwind CSS",
      "Express",
      "Server-Sent Events",
      "PyTorch"
    ],
    "category": "AI Developer Tools",
    "featured": true,
    "mockup": "/images/projects/ThinkingLab-thumbnail.png",
    "longDescription": "ThinkingLab is a visual ML workbench that lets you drag-and-drop neural network architectures onto an infinite canvas, simulate tensor flow in real time, and launch GPU training on AWS with one click. No boilerplate, no infrastructure — just build and train.",
    "hidden": false,
    "architecture": "React frontend using React Flow for canvas management, communicating via Server-Sent Events (SSE) with an Express Node.js backend to stream PyTorch training logs in real-time.",
    "keyChallenges": [
      "Implemented a custom shape-inference algorithm to validate tensor dimensions across connected graph nodes before code export.",
      "Managed complex, deeply nested application state using Zustand, ensuring 60fps rendering even with hundreds of nodes."
    ],
    "metrics": [
      "Supports graphs with 500+ nodes and edges without frame drops.",
      "Reduces PyTorch boilerplate code generation time from hours to seconds."
    ],
    "tagline": "Design, train, and deploy neural networks — visually.",
    "demoUrl": null,
    "liveUrl": "https://thinking-ai-lab.com",
    "publicDescription": "ThinkingLab is a visual ML workbench that lets you drag-and-drop neural network architectures onto an infinite canvas, simulate tensor flow in real time, and launch GPU training on AWS with one click. No boilerplate, no infrastructure — just build and train."
  },
